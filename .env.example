# Logging settings
LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL
ENVIRONMENT=development # development or production

# LLM Providers
OPENAI_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
GROQ_API_KEY=your-api-key

# Observability
LANGFUSE_SECRET_KEY=sk-lf-your-api-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-api-key
LANGFUSE_BASE_URL=http://localhost:3000

# Citation Verification APIs
CROSSREF_MAILTO=you@example.com           # no key needed, just your email
OPENALEX_MAILTO=you@example.com           # no key needed, just your email
SEMANTIC_SCHOLAR_API_KEY=your-api-key     # optional, increases rate limits
NCBI_API_KEY=your-api-key                 # optional, for biomedical references

# Field mode for verification pipeline
FIELD_MODE=cs                             # cs | biomedical | general

# DBLP local database (optional, for offline CS conference paper verification)
# Build with: uv run python scripts/build_dblp_index.py
DBLP_DB_PATH=./data/dblp/dblp.db

# API Security
API_SECRET_KEY=generate-with-openssl-rand-hex-32


