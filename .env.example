# Logging settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# LLM Providers
OPENAI_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
GROQ_API_KEY=your-api-key

# For observability
LANGFUSE_SECRET_KEY=sk-lf-your-api-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-api-key
LANGFUSE_BASE_URL=http://localhost:3000

# Citation Verification APIs (optional) 
# Crossref: no key needed, but polite pool gets better rate limits
CROSSREF_MAILTO=you@example.com

# Semantic Scholar: optional, increases rate limits
SEMANTIC_SCHOLAR_API_KEY=your-api-key

# NCBI / PubMed: optional, for biomedical references
NCBI_API_KEY=your-api-key

